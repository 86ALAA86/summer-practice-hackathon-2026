@model List<clsSport_BLL>
@{
    Layout = "_Layout";
}

<h3>Find a Group</h3>
<p class="text-muted">Select a sport and we'll match you with available players.</p>
<hr />

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">Auto-Match</div>
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Sport</label>
                        <select name="sportID" class="form-select">
                            @foreach (clsSport_BLL sport in Model)
                            {
                                <option value="@sport.SportID">
                                    @sport.SportName (@sport.MinGroupSize–@sport.MaxGroupSize players)
                                </option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-success w-100">
                        <i class="bi bi-people-fill"></i> Match Me Now
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>