@{ Layout = "_Layout"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Group #@ViewBag.GroupID</h3>
    <div class="d-flex gap-2">
        <a href="/Message/Chat/@ViewBag.GroupID" class="btn btn-primary">
            <i class="bi bi-chat-dots-fill"></i> Group Chat
        </a>
        <a href="/Venue/Suggest/@ViewBag.GroupID" class="btn btn-outline-secondary">
            <i class="bi bi-geo-alt-fill"></i> Suggest Venue
        </a>
        <a href="/Poll/Create/@ViewBag.GroupID" class="btn btn-outline-warning">
            <i class="bi bi-bar-chart-fill"></i> Create Poll
        </a>
        <a href="/Group/Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">Members</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Name</th><th>Skill</th><th>Confirmed</th></tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.Members != null)
                        {
                            foreach (clsGroupMember m in ViewBag.Members)
                            {
                                <tr>
                                    <td>@m.FullName</td>
                                    <td>@(string.IsNullOrEmpty(m.SkillLevel) ? "—" : m.SkillLevel)</td>
                                    <td>
                                        @if (m.HasConfirmed)
                                        { <span class="badge bg-success">Yes</span> }
                                        else
                                        { <span class="badge bg-secondary">Pending</span> }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-warning text-dark">Venue Suggestions</div>
            <div class="card-body">
                @if (ViewBag.Venues != null && ((List<clsVenue>)ViewBag.Venues).Any())
                {
                    foreach (clsVenue v in ViewBag.Venues)
                    {
                        <div class="mb-2 p-2 border rounded">
                            <strong>@v.VenueName</strong>
                            @if (!string.IsNullOrEmpty(v.Address))
                            { <span class="text-muted"> — @v.Address</span> }
                            @if (v.PriceEst.HasValue)
                            { <span class="badge bg-secondary ms-1">~@v.PriceEst RON</span> }
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">No venues suggested yet.</p>
                }
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-info text-white">Polls</div>
            <div class="card-body">
                @if (ViewBag.Polls != null && ((List<clsPoll>)ViewBag.Polls).Any())
                {
                    foreach (clsPoll p in ViewBag.Polls)
                    {
                        <div class="mb-2 d-flex justify-content-between align-items-center">
                            <span>@p.Question</span>
                            <a href="/Poll/Results/@p.PollID" class="btn btn-sm btn-outline-info">Vote / Results</a>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">No polls yet.</p>
                }
            </div>
        </div>
    </div>
</div>