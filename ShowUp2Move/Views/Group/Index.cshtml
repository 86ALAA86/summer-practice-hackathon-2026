@model List<clsGroup>
@{ Layout = "_Layout"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>My Groups</h3>
    <a href="/Group/RunMatching" class="btn btn-success">
        <i class="bi bi-people-fill"></i> Find a Group
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">You are not in any groups yet.</div>
}
else
{
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-success">
            <tr>
                <th>Sport</th>
                <th>Captain</th>
                <th>Status</th>
                <th>Created</th>
                <th>Confirmed?</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (clsGroup group in Model)
            {
                <tr>
                    <td>@group.SportName</td>
                    <td>@group.CaptainName</td>
                    <td><span class="badge bg-success">@group.Status</span></td>
                    <td>@group.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        @if (group.HasConfirmed)
                        {
                            <span class="badge bg-success">Yes</span>
                        }
                        else
                        {
                            <form method="post" action="/Group/Confirm">
                                <input type="hidden" name="id" value="@group.GroupID" />
                                <button type="submit" class="btn btn-sm btn-outline-success">Confirm</button>
                            </form>
                        }
                    </td>
                    <td class="d-flex gap-1">
                        <a href="/Group/Detail/@group.GroupID" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-eye"></i> View
                        </a>
                        <a href="/Message/Chat/@group.GroupID" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-chat-dots-fill"></i> Chat
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}