@model clsEvent_BLL
@{
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Event Detail</h3>
    <a href="/Event/Index" class="btn btn-outline-secondary">Back to Events</a>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-success text-white">
        <h5>@Model.SportName</h5>
    </div>
    <div class="card-body">
        <p><strong>Created By:</strong> @Model.CreatedBy</p>
        <p><strong>Location:</strong> @(string.IsNullOrEmpty(Model.Location) ? "TBD" : Model.Location)</p>
        <p><strong>Date:</strong> @Model.EventDate.ToString("dd MMM yyyy HH:mm")</p>
        <p><strong>Description:</strong> @(string.IsNullOrEmpty(Model.Description) ? "—" : Model.Description)</p>
        <p><strong>Type:</strong> @(Model.IsManual ? "Manual" : "Auto-generated")</p>
    </div>
</div>