@{ Layout = "_Layout"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-chat-dots-fill text-primary"></i> Group Chat</h3>
    <a href="/Group/Detail/@ViewBag.GroupID" class="btn btn-outline-secondary">Back to Group</a>
</div>

<div class="card shadow-sm mb-3" style="height:400px; overflow-y:auto;" id="chatBox">
    <div class="card-body">
        @if (ViewBag.Messages != null && ((List<clsMessage>)ViewBag.Messages).Any())
        {
            foreach (clsMessage msg in ViewBag.Messages)
            {
bool isMe = msg.SenderName == Context.Session.GetString("FullName");
                <div class="d-flex @(isMe ? "justify-content-end" : "justify-content-start") mb-2">
                    <div class="p-2 rounded @(isMe ? "bg-success text-white" : "bg-light border")"
                         style="max-width:70%;">
                        @if (!isMe)
                        {
                            <small class="fw-bold d-block">@msg.SenderName</small>
                        }
                        <span>@msg.Content</span>
                        <small class="d-block @(isMe ? "text-white-50" : "text-muted")" style="font-size:11px;">
                            @msg.SentAt.ToString("HH:mm")
                        </small>
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted text-center mt-5">No messages yet. Say hello!</p>
        }
    </div>
</div>

<form method="post" action="/Message/Send" class="d-flex gap-2">
    <input type="hidden" name="groupID" value="@ViewBag.GroupID" />
    <input type="text" name="content" class="form-control" placeholder="Type a message..." required autocomplete="off" />
    <button type="submit" class="btn btn-success px-4">
        <i class="bi bi-send-fill"></i>
    </button>
</form>

<script>
    // Auto-scroll to bottom of chat
    var chatBox = document.getElementById('chatBox');
    chatBox.scrollTop = chatBox.scrollHeight;
</script>