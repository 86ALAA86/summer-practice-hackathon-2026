@model clsUser
@{ Layout = "_Layout"; }

<h3>My Profile</h3>
<hr />

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.ProfilePhotoUrl))
                {
                    <img src="@Model.ProfilePhotoUrl" class="rounded-circle mb-3"
                         width="100" height="100" style="object-fit:cover;" />
                }
                else
                {
                    <i class="bi bi-person-circle text-secondary" style="font-size:80px;"></i>
                }
                <h5 class="mt-2">@Model.FullName</h5>
                <p class="text-muted small">@Model.Username</p>
                <span class="badge bg-success">@(string.IsNullOrEmpty(Model.SkillLevel) ? "No level set" : Model.SkillLevel)</span>
            </div>
        </div>

        <div class="card shadow-sm mt-3">
            <div class="card-header bg-secondary text-white">Upload Photo</div>
            <div class="card-body">
                <form method="post" action="/Profile/UploadPhoto" enctype="multipart/form-data">
                    <div class="mb-2">
                        <input type="file" name="photo" class="form-control" accept="image/*" />
                    </div>
                    <button type="submit" class="btn btn-secondary w-100">Upload</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-success text-white">Edit Info</div>
            <div class="card-body">
                <form method="post" action="/Profile/Edit">
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input type="text" name="fullName" class="form-control" value="@Model.FullName" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">About Me</label>
                        <textarea name="description" class="form-control" rows="3">@Model.Description</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Skill Level</label>
                        <select name="skillLevel" class="form-select">
                           <option value="Beginner" selected="@(Model.SkillLevel == "Beginner")">Beginner</option>
<option value="Intermediate" selected="@(Model.SkillLevel == "Intermediate")">Intermediate</option>
<option value="Advanced" selected="@(Model.SkillLevel == "Advanced")">Advanced</option>

                        </select>
                    </div>
                    <button type="submit" class="btn btn-success">Save Changes</button>
                </form>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-header bg-success text-white">My Sports</div>
            <div class="card-body">
                @if (ViewBag.UserSports != null && ((List<clsSport>)ViewBag.UserSports).Any())
                {
                    foreach (clsSport sport in ViewBag.UserSports)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span><i class="bi bi-trophy-fill text-success"></i> @sport.SportName</span>
                            <form method="post" action="/Profile/DeleteSport">
                                <input type="hidden" name="sportID" value="@sport.SportID" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No sports added yet.</p>
                }
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-secondary text-white">Add a Sport</div>
            <div class="card-body">
                <form method="post" action="/Profile/AddSport" class="d-flex gap-2">
                    <select name="sportID" class="form-select">
                        @if (ViewBag.AllSports != null)
                        {
                            foreach (clsSport sport in ViewBag.AllSports)
                            {
                                <option value="@sport.SportID">@sport.SportName</option>
                            }
                        }
                    </select>
                    <button type="submit" class="btn btn-success">Add</button>
                </form>
            </div>
        </div>
    </div>
</div>